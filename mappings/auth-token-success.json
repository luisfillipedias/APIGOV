{
  "request": {
    "method": "POST",
    "url": "/oauth/token",
    "headers": {
      "Content-Type": {
        "contains": "application/x-www-form-urlencoded"
      }
    },
    "bodyPatterns": [
      {
        "contains": "grant_type=authorization_code"
      },
      {
        "contains": "code=fake-auth-code-123"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "access_token": "mock-govbr-access-token-12345",
      "token_type": "Bearer",
      "expires_in": 3600
    }
  }
}
