{
  "request": {
    "method": "POST",
    "url": "/oauth/token",
    "headers": {
      "Content-Type": {
        "contains": "application/x-www-form-urlencoded"
      }
    },
    "bodyPatterns": [
      {
        "contains": "code=error-code-401"
      }
    ]
  },
  "response": {
    "status": 401,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "error": "invalid_grant",
      "error_description": "Código de autorização expirado ou inválido"
    }
  }
}
